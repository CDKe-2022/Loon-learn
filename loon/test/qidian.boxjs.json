{
  "id": "qidian.ads.sub",
  "name": "KeHuang脚本订阅",
  "description": "起点读书自动广告任务（任务1/2/3）+ BoxJS 可视化配置",
  "author": "@KeHuang",
  "icon": "https://raw.githubusercontent.com/chxm1023/Script_X/main/icon/qidian.png",
  "repo": "https://github.com/CDKe-2022/Loon-learn",
  "apps": [
    {
      "id": "qidian.ads",
      "name": "起点读书",
      "keys": [
        "qd_taskId",
        "qd_session",
        "qd_taskId_2",
        "qd_session_2",
        "qd_reading_task_subid_1",
        "qd_reading_session_1",
        "qd_reading_task_subid_2",
        "qd_reading_session_2",
        "qd_reading_task_subid_3",
        "qd_reading_session_3",
