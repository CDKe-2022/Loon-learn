          "val": "",
          "type": "text",
          "placeholder": "自动获取",
          "desc": "阅读页-广告·加点！组2的子任务ID"
        },
        {
          "id": "qd_reading_session_2",
          "name": "任务三-组2：Session 数据",
          "val": "",
          "type": "textarea",
          "placeholder": "自动获取 (用完即焚)",
          "desc": "阅读页广告组2的请求体，执行后会被脚本自动清空"
        },
        {
          "id": "qd_reading_task_subid_3",
          "name": "任务三-组3：加点 SubId",
