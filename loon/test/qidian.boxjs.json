          "desc": "福利中心-限时彩蛋的任务ID，脚本自动捕获"
        },
        {
          "id": "qd_session_2",
          "name": "任务二：Session 数据",
          "val": "",
          "type": "textarea",
          "placeholder": "自动获取，包含Url/Headers/Body",
          "desc": "任务二完整请求体（含Argus签名），建议不要手动修改"
        },
        {
          "id": "qd_reading_task_subid_1",
          "name": "任务三-组1：加点 SubId",
          "val": "",
