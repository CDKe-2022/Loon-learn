        },
        {
          "id": "qd_session",
          "name": "任务一：Session 数据",
          "val": "",
          "type": "textarea",
          "placeholder": "自动获取，包含Url/Headers/Body",
          "desc": "任务一完整请求体（含Argus签名），建议不要手动修改"
        },
        {
          "id": "qd_taskId_2",
          "name": "任务二：限时彩蛋 TaskId",
          "val": "",
          "type": "text",
